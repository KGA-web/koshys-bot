# ===========================================
# KGI CHATBOT - ENVIRONMENT VARIABLES
# ===========================================

# 1. Get from: https://platform.openai.com/api-keys
# (Free $5 credit for new accounts)
OPENAI_API_KEY=sk-your-openai-key-here

# 2. Model to use (gpt-3.5-turbo is cheaper, gpt-4 is smarter)
OPENAI_MODEL=gpt-3.5-turbo

# ===========================================
# GOOGLE SHEETS CONFIGURATION
# ===========================================
# From your downloaded JSON file:
GOOGLE_SERVICE_ACCOUNT_EMAIL=kgi-947@koshys-bot.iam.gserviceaccount.com

# Copy the private key from JSON (replace actual newlines with \n)
GOOGLE_PRIVATE_KEY=-----BEGIN PRIVATE KEY-----\nYOUR_PRIVATE_KEY_HERE\n-----END PRIVATE KEY-----

# Get from your Google Sheet URL:
# https://docs.google.com/spreadsheets/d/THIS_PART/edit
GOOGLE_SHEET_ID=your-sheet-id-here

# ===========================================
# VAPI.AI VOICE CONFIGURATION
# ===========================================
# Get from: https://dashboard.vapi.ai (free credits available)
VAPI_API_KEY=your-vapi-key-here

# ===========================================
# DEPLOYMENT
# ===========================================
NEXT_PUBLIC_API_URL=https://your-vercel-app.vercel.app